@using Microsoft.AspNetCore.Components.Web
@using SteelPans.WebApp.Services
@implements IDisposable

<div class="sp-section midi-playback">
    <div class="midi-playback__top-row">
        <input class="midi-playback__slider"
               type="range"
               min="0"
               max="@MaxSecondsString"
               step="0.01"
               value="@DisplaySecondsString"
               style="--value:@DisplaySecondsString; --max:@MaxSecondsString;"
               aria-label="Playback position"
               @oninput="HandleSliderInput"
               @onchange="HandleSliderChange"
               @onmousedown="BeginSeek"
               @onmouseup="EndSeek"
               @ontouchstart="BeginSeek"
               @ontouchend="EndSeek" />
    </div>

    <div class="midi-playback__bottom-row">
        <span class="midi-playback__time midi-playback__time--current">@FormatTime(DisplayTime)</span>

        <div class="midi-playback__controls">
            <button class="midi-playback__button midi-playback__button--secondary"
                    type="button"
                    title="Back to start"
                    aria-label="Back to start"
                    disabled="@(!CanGoToStart)"
                    @onclick="HandleBackToStart">
                <span class="bi bi-skip-start-fill" aria-hidden="true"></span>
            </button>

            <button class="midi-playback__button midi-playback__button--primary"
                    type="button"
                    title="@(Playback.IsPlaying ? "Pause" : "Play")"
                    aria-label="@(Playback.IsPlaying ? "Pause" : "Play")"
                    @onclick="HandlePlayPause">
                <span class="bi @(Playback.IsPlaying ? "bi-pause-fill" : "bi-play-fill")" aria-hidden="true"></span>
            </button>

            <button class="midi-playback__button midi-playback__button--secondary"
                    type="button"
                    title="Next track"
                    aria-label="Next track"
                    disabled="@(!CanGoNext)"
                    @onclick="HandleNextTrack">
                <span class="bi bi-skip-end-fill" aria-hidden="true"></span>
            </button>
        </div>

        <span class="midi-playback__time midi-playback__time--total">@FormatTime(Playback.Duration)</span>
    </div>
</div>

@code {
    [Inject] private MidiPlaybackService Playback { get; set; } = default!;

    private bool isSeeking_;
    private double previewSeconds_;

    private TimeSpan DisplayTime => isSeeking_
        ? TimeSpan.FromSeconds(previewSeconds_)
        : ClampTime(Playback.Position);

    private double MaxSeconds => Math.Max(Playback.Duration.TotalSeconds, 0.01);

    private string MaxSecondsString => MaxSeconds.ToString(
        "0.##",
        System.Globalization.CultureInfo.InvariantCulture);

    private string DisplaySecondsString => Math.Clamp(DisplayTime.TotalSeconds, 0, MaxSeconds)
        .ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private bool CanGoToStart => Playback.Position > TimeSpan.Zero;
    private bool CanGoNext => Playback.Position < Playback.Duration;

    protected override void OnInitialized()
    {
        Playback.StateChanged += HandlePlaybackStateChangedAsync;
    }

    protected override void OnParametersSet()
    {
        if (!isSeeking_)
            previewSeconds_ = ClampSeconds(Playback.Position.TotalSeconds);
    }

    private async Task HandlePlaybackStateChangedAsync()
    {
        if (!isSeeking_)
            previewSeconds_ = ClampSeconds(Playback.Position.TotalSeconds);

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandlePlayPause()
    {
        await Playback.ToggleAsync();
    }

    private async Task HandleBackToStart()
    {
        if (!CanGoToStart)
            return;

        await Playback.SeekToStartAsync();
    }

    private async Task HandleNextTrack()
    {
        if (!CanGoNext)
            return;

        await Playback.GoToEndAsync();
    }

    private void BeginSeek()
    {
        isSeeking_ = true;
    }

    private async Task EndSeek()
    {
        await CommitPreviewAsync();
    }

    private async Task HandleSliderInput(ChangeEventArgs args)
    {
        isSeeking_ = true;
        previewSeconds_ = ParseSeconds(args.Value);
        await Playback.PreviewSeekAsync(TimeSpan.FromSeconds(previewSeconds_));
    }

    private async Task HandleSliderChange(ChangeEventArgs args)
    {
        previewSeconds_ = ParseSeconds(args.Value);
        await CommitPreviewAsync();
    }

    private async Task CommitPreviewAsync()
    {
        previewSeconds_ = ClampSeconds(previewSeconds_);
        isSeeking_ = false;

        await Playback.CommitSeekAsync(TimeSpan.FromSeconds(previewSeconds_));
        await InvokeAsync(StateHasChanged);
    }

    private double ParseSeconds(object? value)
    {
        if (value is null)
            return 0;

        return double.TryParse(
            value.ToString(),
            System.Globalization.NumberStyles.Float,
            System.Globalization.CultureInfo.InvariantCulture,
            out var seconds)
            ? ClampSeconds(seconds)
            : 0;
    }

    private double ClampSeconds(double seconds) => Math.Clamp(seconds, 0, MaxSeconds);

    private TimeSpan ClampTime(TimeSpan time) => TimeSpan.FromSeconds(ClampSeconds(time.TotalSeconds));

    private static string FormatTime(TimeSpan time)
    {
        var totalHours = (int)time.TotalHours;

        return totalHours > 0
            ? $"{totalHours}:{time.Minutes:00}:{time.Seconds:00}.{time.Milliseconds:000}"
            : $"{time.Minutes}:{time.Seconds:00}.{time.Milliseconds:000}";
    }

    public void Dispose()
    {
        Playback.StateChanged -= HandlePlaybackStateChangedAsync;
    }
}