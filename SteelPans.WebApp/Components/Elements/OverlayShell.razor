<div class="@ShellClass">
    <button class="@ToggleHeaderClass"
            type="button"
            @onclick="ToggleAsync"
            aria-expanded="@IsOpen"
            aria-label="@Label">
        <div class="@ToggleButtonClass">
            <i class="@CurrentIconClass pans-page__overlay-toggle-icon" aria-hidden="true"></i>
            <span class="pans-page__overlay-toggle-label">@Label</span>
        </div>

        @if (IsOpen && HeaderContent is not null)
        {
            <span class="pans-page__overlay-toggle-extra" @onclick:stopPropagation="true">
                @HeaderContent
            </span>
        }
    </button>

    <div class="@BodyWrapClass"
         aria-hidden="@(!IsOpen)">
        <div class="@BodyClass">
            @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Side { get; set; } = "left";

    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public string IconClass { get; set; } = "bi bi-sliders";

    [Parameter]
    public string OpenIconClass { get; set; } = "bi bi-x-lg";

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public string? PanelVariantClass { get; set; }

    [Parameter]
    public string? BodyVariantClass { get; set; }

    [Parameter]
    public RenderFragment? HeaderContent { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string CurrentIconClass => IsOpen ? OpenIconClass : IconClass;

    private string ShellClass =>
        string.Join(
            " ",
            new[]
            {
                "pans-page__overlay-shell",
                $"pans-page__overlay-shell--{Side}",
                IsOpen ? "pans-page__overlay-shell--open" : "pans-page__overlay-shell--closed"
            });

    private const string ToggleHeaderClass = "pans-page__overlay-toggle pans-page__overlay-toggle--shell";
    private const string ToggleButtonClass = "pans-page__overlay-toggle-button";

    private string BodyWrapClass =>
        string.Join(
            " ",
            new[]
            {
                "pans-page__overlay-panel-body-wrap",
                IsOpen ? "pans-page__overlay-panel-body-wrap--open" : "pans-page__overlay-panel-body-wrap--closed",
                PanelVariantClass
            }.Where(static x => !string.IsNullOrWhiteSpace(x)));

    private string BodyClass =>
        string.Join(
            " ",
            new[]
            {
                "pans-page__overlay-panel-body",
                BodyVariantClass
            }.Where(static x => !string.IsNullOrWhiteSpace(x)));

    private async Task ToggleAsync()
    {
        await IsOpenChanged.InvokeAsync(!IsOpen);
    }
}