@using Microsoft.AspNetCore.Components.Forms
@using SteelPans.WebApp.Components
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Extensions
@inherits OverlayComponentBase

<div class="sp-section midi-loader">
    <div class="midi-loader__top">
        <label class="form-label">MIDI file</label>
    </div>

    <div class="midi-loader__row @(HasTracks ? "midi-loader__row--with-menu" : null)">
        <div class="midi-loader__file">
            <FilePicker FileName="@FileName"
                        OnSingleFileSelected="OnSingleMidiSelected"
                        OnMultipleFileSelected="OnMultipleMidiSelected"
                        Accept="@(["mid", "midi"])" />
        </div>

        @if (HasTracks)
        {
            <div class="midi-loader__menu-wrap">
                <button type="button"
                        class="midi-loader__menu-button"
                        title="Show tracks"
                        aria-label="Show tracks"
                        aria-expanded="@showTrackOverlay_.ToString().ToLowerInvariant()"
                        @onclick="ToggleTrackOverlay">
                    <span class="bi bi-music-note-list"></span>
                </button>

                <div class="midi-loader__track-overlay @(showTrackOverlay_ ? "midi-loader__track-overlay--open" : null)"
                     aria-hidden="@(!showTrackOverlay_).ToString().ToLowerInvariant()">
                    <div class="midi-loader__track-overlay-header">
                        <span class="midi-loader__track-overlay-title">Tracks</span>
                        <button type="button"
                                class="midi-loader__track-overlay-close"
                                aria-label="Close tracks"
                                @onclick="OnCloseAsync">
                            <span class="bi bi-x-lg"></span>
                        </button>
                    </div>

                    <div class="midi-loader__track-list">
                        @foreach (var track in Tracks)
                        {
                            <div class="midi-loader__track-item">
                                <div class="midi-loader__track-details">
                                    <div class="midi-loader__track-name">@track.DisplayInfo</div>
                                    <div class="midi-loader__track-meta">@GetMetaInfo(track)</div>
                                </div>
                                <button type="button"
                                        class="midi-loader__track-button @(IsTrackAssigned(track) ? "midi-loader__track-button-close" : "")"
                                        aria-label="Add/Remove Track"
                                        @onclick="async () => await OnTrackButtonPressed(track)">
                                    <span class="bi @(!IsTrackAssigned(track) ? "bi-plus-lg" : "bi-dash-lg")" />
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string FileName { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<MidiTrackInfo> Tracks { get; set; } = [];

    [Parameter]
    public IReadOnlyList<MidiTrackAssignment> Assignments { get; set; } = [];

    [Parameter]
    public EventCallback OnOverlayOpened { get; set; }

    [Parameter]
    public EventCallback<IBrowserFile> OnSingleMidiSelected { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyList<IBrowserFile>> OnMultipleMidiSelected { get; set; }

    [Parameter]
    public EventCallback<MidiTrackInfo> OnTrackAdded { get; set; }

    [Parameter]
    public EventCallback<MidiTrackInfo> OnTrackRemoved { get; set; }

    private HashSet<int> AssignedTracks =>
        Tracks
            .Where(t => Assignments.Any(a => a.TrackIndex == t.Index))
            .OrderBy(t => t.Index)
            .Select(t => t.Index)
            .ToHashSet();

    private bool HasTracks => Tracks.Count > 0;
    private bool showTrackOverlay_;

    private async Task ToggleTrackOverlay()
    {
        showTrackOverlay_ = !showTrackOverlay_;
        if (showTrackOverlay_)
            await OnOpenAsync();
    }

    public override async Task OnCloseAsync()
    {
        showTrackOverlay_ = false;
        await Task.CompletedTask;
    }

    private bool IsTrackAssigned(MidiTrackInfo track)
    {
        return AssignedTracks.Contains(track.Index);
    }

    private async Task OnTrackButtonPressed(MidiTrackInfo track)
    {
        if (IsTrackAssigned(track))
        {
            await OnTrackRemoved.InvokeAsync(track);
        }
        else
        {
            await OnCloseAsync();
            await OnTrackAdded.InvokeAsync(track);
        }
    }

    private string GetMetaInfo(MidiTrackInfo track)
    {
        return $"{track.NoteCount} note{(track.NoteCount == 1 ? "" : "s")}{(AssignedTracks.Contains(track.Index) ? " - Assigned" : "")}";
    }
}