@inject SteelPanSvgService SvgService
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (Pan is not null)
{
    <div class="steel-pan__controls mb-3">
        <select id="pan-select"
                class="form-select"
                value="@clickType_"
                @onchange="OnClickTypeChanged">
            <option value="@ClickType.Toggle">@ClickType.Toggle</option>
            <option value="@ClickType.Hold">@ClickType.Hold</option>
        </select>

        <button class="btn btn-primary"
                type="button"
                @onclick="PlaySelectedNotesAsync"
                disabled="@(!CanPlaySelectedNotes)">
            Play
        </button>
    </div>

    <div class="steel-pan @Class" style="@Style">
        @((MarkupString)panSvg_)
    </div>
}

@code {
    [Parameter, EditorRequired]
    public SteelPan? Pan { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private readonly string componentId_ = $"steelpan_{Guid.NewGuid():N}";
    private DotNetObjectReference<SteelPanView>? selfRef_;
    private string panSvg_ = string.Empty;
    private string? basePath_;

    private enum ClickType
    {
        Toggle,
        Hold,
    }

    private ClickType clickType_ = ClickType.Hold;

    private bool CanPlaySelectedNotes =>
        clickType_ == ClickType.Toggle &&
        Pan?.Notes.Any(n => n.Active) == true;

    protected override void OnInitialized()
    {
        selfRef_ = DotNetObjectReference.Create(this);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Pan is null)
        {
            panSvg_ = string.Empty;
            basePath_ = string.Empty;
            return;
        }

        basePath_ = $"images/pans/{Pan.PanType.ToKebabCase()}";

        await JS.InvokeVoidAsync(
            "steelPan.preloadNotes",
            (object)Pan.Notes.Select(n => n.ToString()).Distinct().ToArray());


        await SvgService.PrebuildNoteFragmentsAsync(
            $"{basePath_}/base.svg",
            Pan.Notes);

        await RebuildSvgAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (selfRef_ is null)
            return;

        if (firstRender)
        {
            await JS.InvokeVoidAsync("steelPan.register", componentId_, selfRef_);
        }

        await JS.InvokeVoidAsync("steelPan.setClickType", componentId_, clickType_.ToString());
    }

    private async Task RebuildSvgAsync()
    {
        if (Pan is null || string.IsNullOrWhiteSpace(basePath_))
        {
            panSvg_ = string.Empty;
            return;
        }

        panSvg_ = await SvgService.BuildPanSvgAsync(
            $"{basePath_}/base.svg",
            componentId_,
            Pan.Notes);
    }

    private async Task OnClickTypeChanged(ChangeEventArgs e)
    {
        if (!Enum.TryParse<ClickType>(e.Value?.ToString(), out var newClickType))
            return;

        if (newClickType == clickType_)
            return;

        clickType_ = newClickType;

        if (clickType_ == ClickType.Hold && Pan is not null)
        {
            foreach (var note in Pan.Notes)
            {
                note.Active = false;
            }

            await RebuildSvgAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task PlaySelectedNotesAsync()
    {
        if (Pan is null || clickType_ != ClickType.Toggle)
            return;

        var selectedNotes = Pan.Notes
            .Where(n => n.Active)
            .Select(n => n.ToString())
            .Distinct()
            .ToArray();

        if (selectedNotes.Length == 0)
            return;

        await JS.InvokeVoidAsync("steelPan.playNotes", (object)selectedNotes);
    }

    [JSInvokable]
    public async Task ActivateNote(string noteKey)
    {
        if (Pan is null)
            return;

        var note = Pan.Notes.FirstOrDefault(n => n.ToString() == noteKey);
        if (note is null || note.Active)
            return;

        note.Active = true;
        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task DeactivateNote(string noteKey)
    {
        if (Pan is null)
            return;

        var note = Pan.Notes.FirstOrDefault(n => n.ToString() == noteKey);
        if (note is null || !note.Active)
            return;

        note.Active = false;
        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("steelPan.unregister", componentId_);
        }
        catch
        {
        }

        selfRef_?.Dispose();
    }
}