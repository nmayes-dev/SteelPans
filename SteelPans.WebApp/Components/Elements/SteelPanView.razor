@using System.Diagnostics
@using NAudio.Wave
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Services
@using SteelPans.WebApp.Extensions
@inject SteelPanSvgService SvgService
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@implements IAsyncDisposable

@if (Pan is not null)
{
    <div class="steel-pan__root">
        <div class="steel-pan__canvas">
            <div class="steel-pan @Class" style="@Style">
                @((MarkupString)panSvg_)
            </div>
        </div>
    </div>
}
else
{
    <div class="steel-pan steel-pan--empty">
        No pan loaded.
    </div>
}

@code {
    private bool notesPreloaded_;

    [Parameter, EditorRequired]
    public SteelPan? Pan { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private readonly string componentId_ = $"steelpan_{Guid.NewGuid():N}";
    private DotNetObjectReference<SteelPanView>? selfRef_;
    private string panSvg_ = string.Empty;
    private string svgPath_ = string.Empty;
    private TimeSpan sampleDuration_;
    private CancellationTokenSource? playSelectedCts_;

    private Task? midiVisualTask_;

    public Task MidiPlaybackCompletion
        => midiVisualTask_ ?? Task.CompletedTask;

    protected override Task OnInitializedAsync()
    {
        selfRef_ = DotNetObjectReference.Create(this);
        sampleDuration_ = GetWavDuration();
        return Task.CompletedTask;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Pan is null)
        {
            panSvg_ = string.Empty;
            svgPath_ = string.Empty;
            return;
        }

        notesPreloaded_ = false;
        svgPath_ = $"images/pans/{Pan.PanType.ToKebabCase()}.svg";

        await SvgService.PrebuildNoteFragmentsAsync(
            svgPath_,
            Pan.Notes);

        await RebuildSvgAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && selfRef_ is not null)
            await JS.InvokeVoidAsync("steelPan.register", componentId_, selfRef_);

        if (!notesPreloaded_ && Pan is not null)
        {
            await JS.InvokeVoidAsync(
                "steelPan.preloadNotes",
                (object)Pan.Notes.Select(n => n.ToString()).Distinct().ToArray());

            notesPreloaded_ = true;
        }
    }

    private async Task RebuildSvgAsync()
    {
        if (Pan is null || string.IsNullOrWhiteSpace(svgPath_))
        {
            panSvg_ = string.Empty;
            return;
        }

        panSvg_ = await SvgService.BuildPanSvgAsync(
            svgPath_,
            componentId_,
            Pan.Notes);
    }

    [JSInvokable]
    public async Task HandleNoteInteraction(string noteKey, bool shiftKey)
    {
        if (Pan is null)
            return;

        var note = Pan.Notes.FirstOrDefault(n => n.ToString() == noteKey);
        if (note is null)
            return;

        if (!shiftKey)
            return;

        note.Selected = !note.Selected;

        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    public async Task SelectChordAsync(HashSet<int> pitchClasses)
    {
        if (Pan is null)
            return;

        playSelectedCts_?.Cancel();
        playSelectedCts_?.Dispose();
        playSelectedCts_ = null;

        foreach (var note in Pan.Notes)
        {
            note.Selected = pitchClasses.Contains(note.Note.PitchClass);
            note.Playing = false;
        }

        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    public async Task PlaySelectedNotesAsync()
    {
        if (Pan is null)
            return;

        var selectedNotes = Pan.Notes
            .Where(n => n.Selected)
            .ToArray();

        if (selectedNotes.Length == 0)
            return;

        var selectedNoteKeys = selectedNotes
            .Select(n => n.ToString())
            .Distinct()
            .ToArray();

        playSelectedCts_?.Cancel();
        playSelectedCts_?.Dispose();

        foreach (var note in Pan.Notes)
            note.Playing = false;

        var cts = new CancellationTokenSource();
        playSelectedCts_ = cts;

        foreach (var note in selectedNotes)
            note.Playing = true;

        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);

        await JS.InvokeVoidAsync("steelPan.playNotes", (object)selectedNoteKeys);

        _ = ClearSelectedAfterDelayAsync(selectedNotes, cts);
    }

    private async Task ClearSelectedAfterDelayAsync(PanNote[] notes, CancellationTokenSource cts)
    {
        try
        {
            await Task.Delay(sampleDuration_, cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (cts.IsCancellationRequested || playSelectedCts_ != cts)
            return;

        foreach (var note in notes)
        {
            note.Playing = false;
        }

        if (playSelectedCts_ == cts)
        {
            playSelectedCts_.Dispose();
            playSelectedCts_ = null;
        }

        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    private static List<MidiPanPlaybackAction> BuildPlaybackActions(IEnumerable<MidiPanEvent> events)
    {
        return events
            .SelectMany(e => new[]
            {
                new MidiPanPlaybackAction
                {
                    Note = e.Note,
                    Time = e.Start,
                    IsNoteOn = true,
                },
                new MidiPanPlaybackAction
                {
                    Note = e.Note,
                    Time = e.End,
                    IsNoteOn = false,
                },
            })
            .OrderBy(a => a.Time)
            .ThenBy(a => a.IsNoteOn ? 1 : 0)
            .ToList();
    }

    private static List<MidiPanScheduledAction> BuildScheduledActions(IEnumerable<MidiPanPlaybackAction> actions)
    {
        return actions
            .Select(a => new MidiPanScheduledAction
            {
                NoteKey = a.Note.ToString(),
                TimeSeconds = a.Time.TotalSeconds,
                IsNoteOn = a.IsNoteOn,
            })
            .ToList();
    }

    public async Task<double?> StartMidiSequenceAsync(
        IReadOnlyList<MidiPanEvent> events,
        CancellationToken cancellationToken = default)
    {
        if (Pan is null || events.Count == 0)
            return null;

        foreach (var note in Pan.Notes)
        {
            note.Selected = false;
            note.Playing = false;
        }

        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);

        var playbackActions = BuildPlaybackActions(events);

        if (playbackActions.Count == 0)
            return null;

        var scheduledActions = BuildScheduledActions(playbackActions);

        var startAt = await JS.InvokeAsync<double>(
            "steelPan.playMidiSchedule",
            cancellationToken,
            scheduledActions);

        midiVisualTask_ = RunMidiVisualSequenceAsync(
            playbackActions,
            startAt,
            cancellationToken);

        return startAt;
    }

    private async Task RunMidiVisualSequenceAsync(
        IReadOnlyList<MidiPanPlaybackAction> playbackActions,
        double startAt,
        CancellationToken cancellationToken = default)
    {
        if (Pan is null || playbackActions.Count == 0)
            return;

        var noteLookup = BuildPanNoteLookup(Pan);
        var groupedActions = playbackActions
            .GroupBy(static action => action.Time)
            .OrderBy(static group => group.Key)
            .ToArray();

        var activeCounts = new Dictionary<PanNote, int>();

        try
        {
            foreach (var group in groupedActions)
            {
                cancellationToken.ThrowIfCancellationRequested();

                await DelayUntilAudioTimeAsync(startAt, group.Key, cancellationToken);

                var changed = false;

                foreach (var action in group)
                {
                    if (!TryGetPanNote(noteLookup, action.Note, out var panNote))
                        continue;

                    if (action.IsNoteOn)
                    {
                        activeCounts.TryGetValue(panNote, out var count);
                        activeCounts[panNote] = count + 1;

                        if (!panNote.Playing)
                        {
                            panNote.Playing = true;
                            changed = true;
                        }
                    }
                    else
                    {
                        if (!activeCounts.TryGetValue(panNote, out var count))
                            continue;

                        count--;

                        if (count <= 0)
                        {
                            activeCounts.Remove(panNote);

                            if (panNote.Playing)
                            {
                                panNote.Playing = false;
                                changed = true;
                            }
                        }
                        else
                        {
                            activeCounts[panNote] = count;
                        }
                    }
                }

                if (changed)
                {
                    await RebuildSvgAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        finally
        {
            foreach (var note in Pan.Notes)
                note.Playing = false;

            await RebuildSvgAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    public async Task StopMidiPlaybackAsync()
    {
        await JS.InvokeVoidAsync("steelPan.stopMidiSchedule");

        if (midiVisualTask_ is not null)
        {
            try
            {
                await midiVisualTask_;
            }
            catch (OperationCanceledException)
            {
            }
        }

        if (Pan is null)
            return;

        foreach (var note in Pan.Notes)
            note.Playing = false;

        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    private Dictionary<string, PanNote> BuildPanNoteLookup(SteelPan pan)
    {
        var lookup = new Dictionary<string, PanNote>(StringComparer.Ordinal);

        foreach (var panNote in pan.Notes)
            lookup[GetMidiVisualNoteKey(panNote.Note)] = panNote;

        return lookup;
    }

    private bool TryGetPanNote(
        IReadOnlyDictionary<string, PanNote> noteLookup,
        Note note,
        out PanNote panNote)
    {
        return noteLookup.TryGetValue(GetMidiVisualNoteKey(note), out panNote!);
    }

    private static string GetMidiVisualNoteKey(Note note)
    {
        return $"{(int)note.PitchClass}:{note.Octave}";
    }

    private async Task DelayUntilAudioTimeAsync(
        double startAt,
        TimeSpan actionTime,
        CancellationToken cancellationToken)
    {
        while (true)
        {
            cancellationToken.ThrowIfCancellationRequested();

            var currentAudioTime = await JS.InvokeAsync<double>(
                "steelPan.getAudioTime",
                cancellationToken);

            var targetAudioTime = startAt + actionTime.TotalSeconds;
            var remainingSeconds = targetAudioTime - currentAudioTime;

            if (remainingSeconds <= 0.0)
                return;

            var delay = remainingSeconds > 0.02
                ? TimeSpan.FromMilliseconds(Math.Min(remainingSeconds * 1000.0, 25.0))
                : TimeSpan.FromMilliseconds(1);

            await Task.Delay(delay, cancellationToken);
        }
    }

    private TimeSpan GetWavDuration()
    {
        var samplesPath = Path.Combine(Env.WebRootPath, "audio", "samples");
        var path = Directory.Exists(samplesPath)
            ? Directory.EnumerateFiles(samplesPath, "*.wav", SearchOption.AllDirectories).FirstOrDefault()
            : null;

        if (path is null)
            return TimeSpan.Zero;

        using var reader = new AudioFileReader(path);
        return reader.TotalTime;
    }

    public async ValueTask DisposeAsync()
    {
        playSelectedCts_?.Cancel();
        playSelectedCts_?.Dispose();
        playSelectedCts_ = null;

        try
        {
            await JS.InvokeVoidAsync("steelPan.unregister", componentId_);
        }
        catch
        {
        }

        selfRef_?.Dispose();
    }
}