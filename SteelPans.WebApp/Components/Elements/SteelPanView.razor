@inject SteelPanSvgService SvgService
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (Pan is not null)
{
    <div class="steel-pan__controls mb-3">
        <ChordBuilder OnChordSelected="SelectChordAsync" />

        <div class="d-flex align-items-center gap-3 flex-wrap">
            <button class="btn btn-primary"
                    type="button"
                    @onclick="PlaySelectedNotesAsync"
                    disabled="@(!CanPlaySelectedNotes)">
                Play
            </button>

            <span class="steel-pan__hint text-muted small">
                <span>Click = Play</span>
                <span class="steel-pan__hint-sep">·</span>
                <span>Shift + Click = Toggle</span>
            </span>
        </div>
    </div>

    <div class="steel-pan @Class" style="@Style">
        @((MarkupString)panSvg_)
    </div>
}

@code {
    [Parameter, EditorRequired]
    public SteelPan? Pan { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    private bool CanPlaySelectedNotes => Pan?.Notes.Any(n => n.Active) == true;

    private readonly string componentId_ = $"steelpan_{Guid.NewGuid():N}";
    private DotNetObjectReference<SteelPanView>? selfRef_;
    private string panSvg_ = string.Empty;
    private string svgPath_ = string.Empty;

    protected override void OnInitialized()
    {
        selfRef_ = DotNetObjectReference.Create(this);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Pan is null)
        {
            panSvg_ = string.Empty;
            svgPath_ = string.Empty;
            return;
        }

        svgPath_ = $"images/{Pan.PanType.ToKebabCase()}.svg";

        await JS.InvokeVoidAsync(
            "steelPan.preloadNotes",
            (object)Pan.Notes.Select(n => n.ToString()).Distinct().ToArray());

        await SvgService.PrebuildNoteFragmentsAsync(
            svgPath_,
            Pan.Notes);

        await RebuildSvgAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && selfRef_ is not null)
        {
            await JS.InvokeVoidAsync("steelPan.register", componentId_, selfRef_);
        }
    }

    private async Task RebuildSvgAsync()
    {
        if (Pan is null || string.IsNullOrWhiteSpace(svgPath_))
        {
            panSvg_ = string.Empty;
            return;
        }

        panSvg_ = await SvgService.BuildPanSvgAsync(
            svgPath_,
            componentId_,
            Pan.Notes);
    }

    [JSInvokable]
    public async Task HandleNoteInteraction(string noteKey, bool shiftKey)
    {
        if (Pan is null)
            return;

        var note = Pan.Notes.FirstOrDefault(n => n.ToString() == noteKey);
        if (note is null)
            return;

        if (note.Active)
        {
            note.Active = false;
            await RebuildSvgAsync();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (shiftKey)
        {
            note.Active = true;
            await RebuildSvgAsync();
            await InvokeAsync(StateHasChanged);
            return;
        }

        await JS.InvokeVoidAsync("steelPan.playNote", noteKey);
        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectChordAsync(HashSet<int> pitchClasses)
    {
        if (Pan is null)
            return;

        foreach (var note in Pan.Notes)
        {
            note.Active = pitchClasses.Contains(note.Note.PitchClass);
        }

        await RebuildSvgAsync();
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("steelPan.unregister", componentId_);
        }
        catch
        {
        }

        selfRef_?.Dispose();
    }

    private async Task PlaySelectedNotesAsync()
    {
        if (Pan is null)
            return;

        var activeNoteKeys = Pan.Notes
            .Where(n => n.Active)
            .Select(n => n.ToString())
            .Distinct()
            .ToArray();

        if (activeNoteKeys.Length == 0)
            return;

        await JS.InvokeVoidAsync("steelPan.playNotes", (object)activeNoteKeys);
    }
}