@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Services
@inject MidiPlaybackService Playback

<div class="assigned-pan-toolbar__volume" title="Playback Volume" disabled="@(!OtherPans.Any())">
    <button type="button"
            class="assigned-pan-toolbar__volume-button"
            @onclick="ToggleSolo"
            disabled="@(!OtherPans.Any())"
            aria-label="Toggle Solo">
        <span class="@SoloCssClass"></span>
    </button>

    <button type="button"
            class="assigned-pan-toolbar__volume-button"
            @onclick="ToggleMute"
            aria-label="Toggle Mute">
        <span class="@VolumeCssClass"></span>
    </button>

    <input class="assigned-pan-toolbar__volume-slider"
           type="range"
           min="0"
           max="100"
           step="1"
           value="@VolumePercent"
           @oninput="OnVolumeInput" />

    <span class="assigned-pan-toolbar__volume-value">@VolumePercent%</span>
</div>

@code {
    [Parameter, EditorRequired] public MidiAssignedPan ActivePan { get; set; } = default!;

    private int VolumePercent => (int)Math.Round(Volume * 100.0);
    private double Volume => ActivePan.Muted ? 0.0 : Math.Clamp(ActivePan?.Volume ?? 1.0, 0.0, 1.0);

    private IEnumerable<MidiAssignedPan> OtherPans =>
        Playback.ActivePans.Where(x => x.InstanceId != ActivePan.InstanceId);

    private bool IsSoloing =>
        OtherPans.Any() && OtherPans.All(x => x.Muted) && !ActivePan.Muted;

    private string SoloCssClass => $"bi {(IsSoloing ? "bi-eye" : "bi-eye-slash")}";

    private string VolumeCssClass => $"bi {(ActivePan.Muted || Volume <= 0.0001 ? "bi-volume-mute-fill"
                                                                                    : Volume < 0.5 ? "bi-volume-down-fill"
                                                                                                   : "bi-volume-up-fill")}";

    private async Task OnVolumeInput(ChangeEventArgs e)
    {
        if (e.Value?.ToString() is not { Length: > 0 } raw ||
            !int.TryParse(raw, out var percent))
            return;

        var volume = Math.Clamp(percent / 100.0, 0.0, 1.0);

        await Playback.SetPanVolumeAsync(ActivePan, volume);

        if (volume > 0.0001 && ActivePan.Muted)
            await Playback.SetPanMutedAsync(ActivePan, false);
    }

    private async Task ToggleMute()
    {
        await Playback.SetPanMutedAsync(ActivePan, !ActivePan.Muted);
    }

    private async Task ToggleSolo()
    {
        await Playback.SetPansMutedAsync(OtherPans, !IsSoloing);
        await Playback.SetPanMutedAsync(ActivePan, false);
    }
}