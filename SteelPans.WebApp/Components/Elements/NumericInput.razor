@implements IAsyncDisposable
@inject IJSRuntime JS

<input @ref="inputRef_"
       id="@Id"
       class="@Class"
       type="text"
       inputmode="numeric"
       value="@currentValue_"
       @onchange="HandleInput"
       disabled="@Disabled" />

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public int Value { get; set; }
    [Parameter] public EventCallback<int> ValueChanged { get; set; }
    [Parameter] public int? Min { get; set; }
    [Parameter] public int? Max { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private ElementReference inputRef_;
    private string currentValue_ = string.Empty;

    protected override void OnParametersSet()
    {
        currentValue_ = Value.ToString();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("filters.numeric", inputRef_);
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(raw))
        {
            currentValue_ = Value.ToString();
            await JS.InvokeVoidAsync("filters.setValue", inputRef_, currentValue_);
            return;
        }

        if (!int.TryParse(raw, out var value))
        {
            currentValue_ = Value.ToString();
            await JS.InvokeVoidAsync("filters.setValue", inputRef_, currentValue_);
            return;
        }

        if (Min.HasValue)
            value = Math.Max(Min.Value, value);

        if (Max.HasValue)
            value = Math.Min(Max.Value, value);

        currentValue_ = value.ToString();

        if (value != Value)
            await ValueChanged.InvokeAsync(value);

        // ensure DOM reflects clamped value
        await JS.InvokeVoidAsync("filters.setValue", inputRef_, currentValue_);
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}