@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="metronome">
    <div class="metronome__controls">
        <div class="metronome__header">
            <button class="metronome__status-toggle"
                    type="button"
                    @onclick="ToggleEnabledAsync">
                <span class="badge @MetronomeStatusClass">
                    <span class="metronome__status-label">@MetronomeStatusText</span>
                </span>
            </button>

            <div class="metronome__header-actions">
                <button class="btn btn-outline-secondary metronome__toggle"
                        type="button"
                        @onclick="ToggleManualPlayAsync"
                        disabled="@(playState_ == PlayState.MIDI || !Enabled)">
                    @(playState_ == PlayState.Manual ? "Stop" : "Play")
                </button>
            </div>
        </div>

        <div class="metronome__inputs">
            <div class="metronome__field">
                <div class="metronome__number-input @(IsPlaying ? "metronome__number-input--disabled" : null)">
                    <NumericInput Id="@($"{componentId_}_bpm")"
                                  Class="form-control metronome__bpm-input metronome__number-input-control"
                                  Value="@Bpm"
                                  ValueChanged="SetBpmAsync"
                                  Min="20"
                                  Max="200"
                                  Disabled="@IsPlaying" />

                    <div class="metronome__number-buttons">
                        <button class="metronome__number-button metronome__number-button--up"
                                type="button"
                                @onclick="IncrementBpmAsync"
                                disabled="@IsPlaying"
                                tabindex="-1"
                                aria-label="Increase BPM"></button>

                        <button class="metronome__number-button metronome__number-button--down"
                                type="button"
                                @onclick="DecrementBpmAsync"
                                disabled="@IsPlaying"
                                tabindex="-1"
                                aria-label="Decrease BPM"></button>
                    </div>
                </div>
                <label class="form-label" for="@($"{componentId_}_bpm")">BPM</label>
            </div>

            <div class="metronome__field">
                <div class="metronome__number-input @(IsPlaying ? "metronome__number-input--disabled" : null)">
                    <NumericInput Id="@($"{componentId_}_beatsPerBar")"
                                  Class="form-control metronome__time-signature-input metronome__number-input-control"
                                  Value="@BeatsPerBar"
                                  ValueChanged="SetBeatsPerBarAsync"
                                  Min="1"
                                  Max="32"
                                  Disabled="@IsPlaying" />

                    <div class="metronome__number-buttons">
                        <button class="metronome__number-button metronome__number-button--up"
                                type="button"
                                @onclick="IncrementBeatsPerBarAsync"
                                disabled="@IsPlaying"
                                tabindex="-1"
                                aria-label="Increase beats per bar"></button>

                        <button class="metronome__number-button metronome__number-button--down"
                                type="button"
                                @onclick="DecrementBeatsPerBarAsync"
                                disabled="@IsPlaying"
                                tabindex="-1"
                                aria-label="Decrease beats per bar"></button>
                    </div>
                </div>
                <label class="form-label" for="@($"{componentId_}_beatsPerBar")">Beats / Bar</label>
            </div>

            <div class="metronome__field">
                <div class="metronome__number-input @(IsPlaying ? "metronome__number-input--disabled" : null)">
                    <select id="@($"{componentId_}_beatUnit")"
                            class="form-select metronome__beat-unit-input"
                            value="@BeatUnit"
                            @onchange="OnBeatUnitChanged"
                            disabled="@IsPlaying">
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="4">4</option>
                        <option value="8">8</option>
                        <option value="16">16</option>
                        <option value="32">32</option>
                    </select>
                </div>
                <label class="form-label" for="@($"{componentId_}_beatUnit")">Beat Unit</label>
            </div>
        </div>
    </div>

    <div class="metronome__visual @(Enabled ? null : "metronome__visual--disabled")">
        <div class="metronome__case">
            <div class="metronome__arm-pivot"></div>

            <div class="metronome__arm-wrap">
                <div class="metronome__arm"
                     style="@($"transform: rotate({ArmAngleDeg:F2}deg);")">
                    <div class="metronome__arm-stick"></div>

                    <div class="metronome__arm-weight-track" @ref="weightTrackRef_">
                        <button class="metronome__arm-weight @(CanDragWeight ? "metronome__arm-weight--draggable" : "metronome__arm-weight--locked")"
                                type="button"
                                style="@($"top: {WeightTopPercent:F3}%;")"
                                @onpointerdown="BeginWeightDragAsync"
                                disabled="@(!CanDragWeight)"
                                tabindex="-1"
                                aria-label="Drag to adjust BPM"></button>
                    </div>
                </div>
            </div>

            <div class="metronome__scale">
                <span class="metronome__scale-label metronome__scale-label--largo">Largo</span>
                <span class="metronome__scale-label metronome__scale-label--andante">Andante</span>
                <span class="metronome__scale-label metronome__scale-label--allegro">Allegro</span>
            </div>

            <div class="metronome__light @(tickFlash_ ? (accentFlash_ ? "metronome__light--accent" : "metronome__light--tick") : null)"></div>

            <div class="metronome__beat-display">
                <span class="metronome__beat-number">@displayBeat_</span>
                <span class="metronome__beat-total">/ @BeatsPerBar</span>
            </div>
        </div>
    </div>
</div>