@implements IDisposable

<CascadingValue Value="this" IsFixed="true">
    @ChildContent
</CascadingValue>

<div class="toolbar @(SideClass) @(ActiveElement is not null ? "toolbar--panel-open" : null)">
    @if (ActiveElement is null)
    {
        <div class="toolbar__menu-wrap @(menuOpen_ ? "toolbar__menu-wrap--open" : null)">
            <button class="toolbar__menu-button"
                    type="button"
                    aria-label="@MenuButtonLabel"
                    aria-expanded="@menuOpen_"
                    @onclick="ToggleMenu">
                <span class="bi @(menuOpen_? OpenIconClass : ClosedIconClass)" aria-hidden="true"></span>
            </button>

            @if (menuOpen_ && elements_.Count > 0)
            {
                <div class="toolbar__menu" role="menu" aria-label="@MenuAriaLabel">
                    @for (var i = 0; i < elements_.Count; i++)
                    {
                        var index = i;
                        var element = elements_[index];

                        <button class="toolbar__menu-item"
                                type="button"
                                role="menuitem"
                                @onclick="() => ActivateElementAsync(index)">
                            @if (!string.IsNullOrWhiteSpace(element.IconClass))
                            {
                                <span class="@element.IconClass" aria-hidden="true"></span>
                            }
                            <span>@element.Title</span>

                        </button>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="toolbar__panel">
            <div class="toolbar__panel-header">
                <div class="toolbar__panel-title-wrap">
                    @if (!string.IsNullOrWhiteSpace(ActiveElement.IconClass))
                    {
                        <span class="@ActiveElement.IconClass toolbar__panel-icon" aria-hidden="true"></span>
                    }

                    <span class="toolbar__panel-title">@ActiveElement.Title</span>
                </div>

                <div class="toolbar__panel-header-actions">
                    @if (ActiveElement.HeaderActions is not null)
                    {
                        @ActiveElement.HeaderActions
                    }

                    <button class="toolbar__panel-close"
                            type="button"
                            aria-label="@($"Close {ActiveElement.Title}")"
                            @onclick="CloseActive">
                        <span class="bi bi-x-lg" aria-hidden="true"></span>
                    </button>
                </div>
            </div>

            <div class="toolbar__panel-body">
                @ActiveElement.ChildContent
            </div>
        </div>
    }
</div>