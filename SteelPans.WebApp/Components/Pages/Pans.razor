@page "/"
@page "/pans"
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Services
@using SteelPans.WebApp.Extensions
@inject IJSRuntime JS
@inject SteelPanLoader PanLoader
@inject MidiLoaderService MidiLoader

<div class="pans-page">
    <div class="pans-page__hero">
        <div class="pans-page__hero-content">
            <div>
                <label class="pans-page__eyebrow">Interactive practice tool</label>
                <h1 class="pans-page__title">Steel Pans</h1>
            </div>

            @if (pans_.Count > 0)
            {
                <div class="pans-page__hero-field">
                    <label for="pan-select" class="form-label">Select a pan</label>
                    <select id="pan-select"
                            class="form-select"
                            value="@selectedPanIndex_"
                            @onchange="OnPanChanged">
                        @for (var i = 0; i < pans_.Count; i++)
                        {
                            <option value="@i">@pans_[i].PanType.ToSpacedPascal()</option>
                        }
                    </select>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadError_))
    {
        <div class="alert alert-danger">@loadError_</div>
    }
    else if (pans_.Count == 0)
    {
        <div class="pans-page__empty">No pans found.</div>
    }
    else
    {
        <div class="pans-page__top-controls">
            <div class="pans-page__field pans-page__field--wide">
                <label class="form-label">MIDI file</label>

                <div class="pans-page__midi">
                    <div class="steel-pan__midi-controls">
                        <div class="steel-pan__midi-file-picker">
                            <InputFile id="midi-file"
                                       class="steel-pan__midi-file-input"
                                       OnChange="OnMidiSelected"
                                       accept=".mid,.midi" />

                            <label for="midi-file" class="steel-pan__midi-file-button">
                                Browse
                            </label>

                            <label for="midi-file"
                                   class="steel-pan__midi-file-name @(string.IsNullOrWhiteSpace(midiFileName_) ? "steel-pan__midi-file-name--placeholder" : null)">
                                @(midiFileName_ ?? "No file selected")
                            </label>
                        </div>
                    </div>
                </div>

            </div>
            <div class="pans-page__playback-control">
                <MidiPlaybackControl CurrentTime="@playbackPosition_"
                                     TotalTime="@playbackDuration_"
                                     IsPlaying="@isMidiPlaying_"
                                     CanSeek="@(midiEvents_.Count > 0)"
                                     CanGoToStart="@(playbackPosition_ > TimeSpan.Zero)"
                                     CanGoNext="@(midiEvents_.Count > 0 && playbackPosition_ < playbackDuration_)"
                                     Disabled="@(midiEvents_.Count == 0)"
                                     OnPlayPause="ToggleMidiAsync"
                                     OnBackToStart="SeekToStartAsync"
                                     OnNextTrack="HandleNextTrackAsync"
                                     OnSeekPreviewChanged="HandleSeekPreviewChangedAsync"
                                     OnSeekCommitted="HandleSeekCommittedAsync" />
            </div>
        </div>

        <div class="pans-page__content">
            <div class="pans-page__main">
                <div class="pans-page__main-toggles">
                    <div class="pans-page__overlay-shell pans-page__overlay-shell--left @(showChordBuilderPanel_ ? "pans-page__overlay-shell--open" : "pans-page__overlay-shell--closed")">
                        <div class="pans-page__overlay-shell-container">
                            <button class="pans-page__overlay-toggle pans-page__overlay-toggle--left pans-page__overlay-toggle--shell"
                                    type="button"
                                    @onclick="ToggleChordBuilderPanel"
                                    aria-label="Toggle chord builder"
                                    aria-expanded="@showChordBuilderPanel_"
                                    aria-controls="chord-builder-panel">
                                <span class="pans-page__overlay-toggle-icon bi @(showChordBuilderPanel_ ? "bi-x-lg" : "bi-music-note-list")" aria-hidden="true"></span>
                                <span class="pans-page__overlay-toggle-label">Chord Builder</span>
                            </button>
                        </div>

                        <section id="chord-builder-panel"
                                 class="pans-page__overlay-panel-body-wrap @(showChordBuilderPanel_ ? "pans-page__overlay-panel-body-wrap--open" : "pans-page__overlay-panel-body-wrap--closed")"
                                 aria-label="Chord builder panel"
                                 aria-hidden="@(!showChordBuilderPanel_)">
                            <div class="pans-page__overlay-panel-body">
                                <ChordBuilder OnChordSelected="SelectChordAsync"
                                              OnPlay="PlaySelectedNotesAsync" />
                            </div>
                        </section>
                    </div>

                    <div class="pans-page__overlay-shell pans-page__overlay-shell--right @(showMetronomePanel_ ? "pans-page__overlay-shell--open" : "pans-page__overlay-shell--closed")">
                        <div class="pans-page__overlay-shell-container">
                            <button class="pans-page__overlay-toggle pans-page__overlay-toggle--right pans-page__overlay-toggle--shell"
                                    type="button"
                                    @onclick="ToggleMetronomePanel"
                                    aria-label="Toggle metronome"
                                    aria-expanded="@showMetronomePanel_"
                                    aria-controls="metronome-panel">
                                <span class="pans-page__overlay-toggle-label">Metronome</span>
                                <span class="pans-page__overlay-toggle-icon bi @(showMetronomePanel_ ? "bi-x-lg" : "bi-stopwatch")" aria-hidden="true"></span>
                            </button>
                        </div>

                        <section id="metronome-panel"
                                 class="pans-page__overlay-panel-body-wrap pans-page__overlay-panel-body-wrap--metronome @(showMetronomePanel_ ? "pans-page__overlay-panel-body-wrap--open" : "pans-page__overlay-panel-body-wrap--closed")"
                                 aria-label="Metronome panel"
                                 aria-hidden="@(!showMetronomePanel_)">
                            <div class="pans-page__overlay-panel-body pans-page__overlay-panel-body--metronome">
                                <Metronome @ref="metronome_"
                                           MidiStartAt="@midiStartAt_"
                                           Bpm="@metronomeBpm_"
                                           BpmChanged="OnMetronomeBpmChanged"
                                           BeatsPerBar="@metronomeBeatsPerBar_"
                                           BeatsPerBarChanged="OnMetronomeBeatsPerBarChanged"
                                           BeatUnit="@metronomeBeatUnit_"
                                           BeatUnitChanged="OnMetronomeBeatUnitChanged"
                                           Enabled="@metronomeEnabled_"
                                           EnabledChanged="OnMetronomeEnabledChanged" />
                            </div>
                        </section>
                    </div>
                </div>

                <div class="pans-page__instrument-full">
                    <SteelPanView @ref="steelPanView_" Pan="@SelectedPan" />
                </div>
            </div>
        </div>
    }
</div>