@page "/"
@page "/pans"
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Services
@using SteelPans.WebApp.Extensions
@inject IJSRuntime JS
@inject SteelPanLoader PanLoader
@inject MidiLoaderService MidiLoader

<div class="pans-page">
    <div class="pans-page__hero">
        <div>
            <p class="pans-page__eyebrow">Interactive practice tool</p>
            <h1 class="pans-page__title">Steel Pans</h1>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadError_))
    {
        <div class="alert alert-danger">@loadError_</div>
    }
    else if (pans_.Count == 0)
    {
        <div class="pans-page__empty">No pans found.</div>
    }
    else
    {
        <div class="pans-page__toolbar">
            <div class="pans-page__field">
                <label for="pan-select" class="form-label">Select a pan</label>
                <select id="pan-select"
                        class="form-select"
                        value="@selectedPanIndex_"
                        @onchange="OnPanChanged">
                    @for (var i = 0; i < pans_.Count; i++)
                    {
                        <option value="@i">@pans_[i].PanType.ToSpacedPascal()</option>
                    }
                </select>
            </div>

            <div class="pans-page__field pans-page__field--wide">
                <label class="form-label">MIDI file</label>

                <div class="pans-page__midi">
                    <div class="steel-pan__midi-controls">
                        <div class="steel-pan__midi-row">
                            <div class="steel-pan__midi-file-picker">
                                <InputFile id="midi-file"
                                           class="steel-pan__midi-file-input"
                                           OnChange="OnMidiSelected"
                                           accept=".mid,.midi" />

                                <label for="midi-file" class="steel-pan__midi-file-button">
                                    Browse
                                </label>

                                <div class="steel-pan__midi-file-name @(string.IsNullOrWhiteSpace(midiFileName_) ? "steel-pan__midi-file-name--placeholder" : null)">
                                    @(midiFileName_ ?? "No file selected")
                                </div>
                            </div>

                            @if (midiTracks_.Count > 0)
                            {
                                <select class="form-select steel-pan__midi-track-select"
                                        value="@selectedTrackIndex_"
                                        @onchange="OnTrackChanged">
                                    @foreach (var track in midiTracks_)
                                    {
                                        <option value="@track.Index">
                                            @(!string.IsNullOrWhiteSpace(track.Name)
                                                ? $"Track {track.Index} - {track.Name} - {track.NoteCount} raw notes"
                                                : $"Track {track.Index} - {track.NoteCount} raw notes")
                                        </option>
                                    }
                                </select>
                            }

                            <div class="steel-pan__midi-actions">
                                <button class="btn btn-primary"
                                        type="button"
                                        @onclick="PlayMidiAsync"
                                        disabled="@(midiEvents_.Count == 0 || isMidiPlaying_)">
                                    Play
                                </button>

                                <button class="btn btn-outline-danger"
                                        type="button"
                                        @onclick="StopMidiAsync"
                                        disabled="@(!isMidiPlaying_)">
                                    Stop
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="pans-page__chord-bar">
            <ChordBuilder OnChordSelected="SelectChordAsync"
                          OnPlay="PlaySelectedNotesAsync" />
        </div>

        <div class="pans-page__content">
            <div class="pans-page__instrument-full">
                <SteelPanView @ref="steelPanView_" Pan="@SelectedPan" />
            </div>

            <aside class="pans-page__sidebar">
                <Metronome IsPlaying="@isMidiPlaying_"
                           Bpm="@metronomeBpm_"
                           BpmChanged="OnMetronomeBpmChanged"
                           BeatsPerBar="@metronomeBeatsPerBar_"
                           BeatsPerBarChanged="OnMetronomeBeatsPerBarChanged"
                           BeatUnit="@metronomeBeatUnit_"
                           BeatUnitChanged="OnMetronomeBeatUnitChanged"
                           Enabled="@metronomeEnabled_"
                           EnabledChanged="OnMetronomeEnabledChanged" />
            </aside>
        </div>
    }
</div>

@code {
    private readonly List<SteelPan> pans_ = [];
    private int selectedPanIndex_;
    private string? loadError_;

    private IBrowserFile? midiFile_;
    private string? midiFileName_;
    private List<MidiTrackInfo> midiTracks_ = [];
    private int? selectedTrackIndex_;

    private MidiPlaybackInfo? midiPlaybackInfo_;

    private int metronomeBpm_ = 120;
    private int metronomeBeatsPerBar_ = 4;
    private int metronomeBeatUnit_ = 4;
    private bool metronomeEnabled_ = true;
    private int? midiBpmOverride_;

    private List<MidiPanEvent> midiEvents_ = [];
    private CancellationTokenSource? midiPlaybackCts_;
    private bool isMidiPlaying_;

    private SteelPanView? steelPanView_;

    private SteelPan? SelectedPan =>
        selectedPanIndex_ >= 0 && selectedPanIndex_ < pans_.Count
            ? pans_[selectedPanIndex_]
            : null;

    private int EffectiveMidiBpm =>
        midiBpmOverride_
            ?? midiPlaybackInfo_?.InitialBpm
            ?? metronomeBpm_;

    private sealed class MidiMetronomeChange
    {
        public required TimeSpan Time { get; init; }
        public int? Bpm { get; init; }
        public int? BeatsPerBar { get; init; }
        public int? BeatUnit { get; init; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            pans_.Clear();
            pans_.AddRange(await PanLoader.LoadAsync());
            selectedPanIndex_ = 0;
        }
        catch (Exception ex)
        {
            loadError_ = ex.Message;
        }
    }

    private async Task OnMidiSelected(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0)
            return;

        await StopMidiAsync();

        midiFile_ = e.File;
        midiFileName_ = midiFile_.Name;

        midiTracks_.Clear();
        midiEvents_.Clear();
        selectedTrackIndex_ = null;
        midiPlaybackInfo_ = null;
        midiBpmOverride_ = null;

        await using (var trackInfoStream = midiFile_.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
        {
            midiTracks_ = await MidiLoader.GetTrackInfosAsync(trackInfoStream);
        }

        await using (var playbackInfoStream = midiFile_.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024))
        {
            midiPlaybackInfo_ = await MidiLoader.GetPlaybackInfoAsync(playbackInfoStream);
        }

        if (midiPlaybackInfo_ is not null)
        {
            metronomeBpm_ = midiPlaybackInfo_.InitialBpm;
            metronomeBeatsPerBar_ = midiPlaybackInfo_.InitialBeatsPerBar;
            metronomeBeatUnit_ = midiPlaybackInfo_.InitialBeatUnit;
        }

        selectedTrackIndex_ = midiTracks_
            .OrderByDescending(t => t.NoteCount)
            .Select(t => (int?)t.Index)
            .FirstOrDefault();

        await ReloadSelectedTrackAsync();
    }

    private async Task OnTrackChanged(ChangeEventArgs e)
    {
        if (e.Value is null || !int.TryParse(e.Value.ToString(), out var trackIndex))
            return;

        selectedTrackIndex_ = trackIndex;
        await ReloadSelectedTrackAsync();
    }

    private async Task OnPanChanged(ChangeEventArgs e)
    {
        if (e.Value is null || !int.TryParse(e.Value.ToString(), out var selectedIndex))
            return;

        selectedPanIndex_ = selectedIndex;
        await ReloadSelectedTrackAsync();
    }

    private async Task ReloadSelectedTrackAsync()
    {
        if (midiFile_ is null || selectedTrackIndex_ is null)
        {
            midiEvents_.Clear();
            StateHasChanged();
            return;
        }

        await using var stream = midiFile_.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);

        var rawEvents = await MidiLoader.LoadSingleTrackAsync(
            stream,
            selectedTrackIndex_.Value);

        midiEvents_ = SelectedPan is not null
            ? PanMidiMapper.FilterToPan(SelectedPan, rawEvents)
            : rawEvents;

        StateHasChanged();
    }

    private async Task SelectChordAsync(HashSet<int> pitchClasses)
    {
        if (steelPanView_ is null)
            return;

        await steelPanView_.SelectChordAsync(pitchClasses);
    }

    private async Task PlaySelectedNotesAsync()
    {
        if (steelPanView_ is null)
            return;

        await steelPanView_.PlaySelectedNotesAsync();
    }

    private async Task PlayMidiAsync()
    {
        if (steelPanView_ is null || midiEvents_.Count == 0)
            return;

        midiPlaybackCts_?.Cancel();
        midiPlaybackCts_?.Dispose();

        midiPlaybackCts_ = new CancellationTokenSource();
        isMidiPlaying_ = true;

        if (midiPlaybackInfo_ is not null)
        {
            metronomeBpm_ = EffectiveMidiBpm;
            metronomeBeatsPerBar_ = midiPlaybackInfo_.InitialBeatsPerBar;
            metronomeBeatUnit_ = midiPlaybackInfo_.InitialBeatUnit;
        }

        StateHasChanged();

        try
        {
            Task? metronomeSyncTask = null;

            if (midiPlaybackInfo_ is not null && metronomeEnabled_)
            {
                metronomeSyncTask = SyncMetronomeToMidiAsync(
                    midiPlaybackInfo_,
                    midiPlaybackCts_.Token);
            }

            var playbackEvents = GetPlaybackEvents();

            await steelPanView_.PlayMidiSequenceAsync(playbackEvents, midiPlaybackCts_.Token);

            if (metronomeSyncTask is not null)
                await metronomeSyncTask;
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            isMidiPlaying_ = false;
            StateHasChanged();
        }
    }

    private async Task StopMidiAsync()
    {
        if (midiPlaybackCts_ is not null)
        {
            midiPlaybackCts_.Cancel();
            midiPlaybackCts_.Dispose();
            midiPlaybackCts_ = null;
        }
        
        await JS.InvokeVoidAsync("steelPan.stopMidiSchedule");

        isMidiPlaying_ = false;

        if (steelPanView_ is not null)
            await steelPanView_.StopMidiPlaybackAsync();

        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<MidiPanEvent> GetPlaybackEvents()
    {
        if (midiPlaybackInfo_ is null)
            return midiEvents_;

        var sourceBpm = midiPlaybackInfo_.InitialBpm;
        var targetBpm = EffectiveMidiBpm;

        if (sourceBpm <= 0 || targetBpm <= 0 || sourceBpm == targetBpm)
            return midiEvents_;

        var scale = (double)sourceBpm / targetBpm;

        return midiEvents_
            .Select(e => new MidiPanEvent
            {
                Note = e.Note,
                Start = TimeSpan.FromTicks((long)(e.Start.Ticks * scale)),
                Duration = TimeSpan.FromTicks((long)(e.Duration.Ticks * scale)),
            })
            .ToList();
    }

    private async Task SyncMetronomeToMidiAsync(MidiPlaybackInfo playbackInfo, CancellationToken cancellationToken)
    {
        var changes = BuildMetronomeChanges(playbackInfo);
        var previousTime = TimeSpan.Zero;

        foreach (var change in changes)
        {
            cancellationToken.ThrowIfCancellationRequested();

            var delay = change.Time - previousTime;
            if (delay > TimeSpan.Zero)
                await Task.Delay(delay, cancellationToken);

            previousTime = change.Time;

            if (change.Bpm.HasValue)
                metronomeBpm_ = change.Bpm.Value;

            if (change.BeatsPerBar.HasValue)
                metronomeBeatsPerBar_ = change.BeatsPerBar.Value;

            if (change.BeatUnit.HasValue)
                metronomeBeatUnit_ = change.BeatUnit.Value;

            await InvokeAsync(StateHasChanged);
        }
    }

    private List<MidiMetronomeChange> BuildMetronomeChanges(MidiPlaybackInfo playbackInfo)
    {
        var changes = new List<MidiMetronomeChange>();

        if (midiBpmOverride_ is null)
        {
            foreach (var tempo in playbackInfo.TempoChanges)
            {
                changes.Add(new MidiMetronomeChange
                {
                    Time = tempo.Time,
                    Bpm = tempo.Bpm,
                });
            }
        }

        foreach (var ts in playbackInfo.TimeSignatureChanges)
        {
            changes.Add(new MidiMetronomeChange
            {
                Time = ts.Time,
                BeatsPerBar = ts.Numerator,
                BeatUnit = ts.Denominator,
            });
        }

        return changes
            .OrderBy(c => c.Time)
            .ToList();
    }

    private Task OnMetronomeBpmChanged(int bpm)
    {
        metronomeBpm_ = bpm;

        if (!isMidiPlaying_ && midiPlaybackInfo_ is not null)
            midiBpmOverride_ = bpm;

        return Task.CompletedTask;
    }

    private Task OnMetronomeBeatsPerBarChanged(int beatsPerBar)
    {
        metronomeBeatsPerBar_ = beatsPerBar;
        return Task.CompletedTask;
    }

    private Task OnMetronomeBeatUnitChanged(int beatUnit)
    {
        metronomeBeatUnit_ = beatUnit;
        return Task.CompletedTask;
    }

    private Task OnMetronomeEnabledChanged(bool enabled)
    {
        metronomeEnabled_ = enabled;
        return Task.CompletedTask;
    }
}