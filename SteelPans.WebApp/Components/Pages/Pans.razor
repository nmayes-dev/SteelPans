@page "/"
@page "/pans"
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Services
@using SteelPans.WebApp.Extensions
@inject IJSRuntime JS
@inject SteelPanLoader PanLoader
@inject MidiLoaderService MidiLoader

<div class="pans-page">
    <header class="sp-section pans-page__hero">
        <div class="pans-page__hero-content">
            <div class="pans-page__hero_headings">
                <label class="pans-page__eyebrow">Interactive practice tool</label>
                <h1 class="pans-page__title">Steel Pans</h1>
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(loadError_))
    {
        <div class="alert alert-danger">@loadError_</div>
    }
    else if (pans_.Count == 0)
    {
        <div class="pans-page__empty">No pans found.</div>
    }
    else
    {
        <section class="pans-page__top-grid">
            <MidiLoader Disabled="@isMidiPlaying_"
                        Tracks="@midiTracks_"
                        Assignments="@midiTrackAssignments_"
                        AvailablePanTypes="@availablePanTypes_"
                        OnMidiSelected="OnMidiSelectedAsync"
                        OnAddAssignment="AddTrackAssignmentAsync"
                        OnRemoveAssignment="RemoveTrackAssignmentAsync" />
        </section>

        <section class="pans-page__midi-controls">
            <MidiPlaybackControl CurrentTime="@playbackPosition_"
                                 TotalTime="@playbackDuration_"
                                 IsPlaying="@isMidiPlaying_"
                                 CanSeek="@(activeMidiPans_.Count > 0)"
                                 CanGoToStart="@(playbackPosition_ > TimeSpan.Zero)"
                                 CanGoNext="@(activeMidiPans_.Count > 0 && playbackPosition_ < playbackDuration_)"
                                 Disabled="@(activeMidiPans_.Count == 0)"
                                 OnPlayPause="ToggleMidiAsync"
                                 OnBackToStart="SeekToStartAsync"
                                 OnNextTrack="HandleNextTrackAsync"
                                 OnSeekPreviewChanged="HandleSeekPreviewChangedAsync"
                                 OnSeekCommitted="HandleSeekCommittedAsync" />
        </section>

        @if (activeMidiPans_.Count > 0 )
        {
            <section class="sp-section pans-page__content">
                <div class="pans-page__toolbar">
                    <div class="pans-page__menu-wrap @(showToolsMenu_ ? "pans-page__menu-wrap-open" : "") @(showChordBuilderPanel_ || showMetronomePanel_ ? "pans-page__menu-wrap-hide" : "")">
                        <button class="pans-page__menu-button"
                                type="button"
                                aria-label="Open tools menu"
                                aria-expanded="@showToolsMenu_"
                                @onclick="ToggleToolsMenu">
                            <span class="bi @(showToolsMenu_ ? "bi-x-lg" : "bi-list")" aria-hidden="true"></span>
                        </button>

                        @if (showToolsMenu_)
                        {
                            <div class="pans-page__menu" role="menu" aria-label="Tools menu">
                                <button class="pans-page__menu-item"
                                        type="button"
                                        role="menuitem"
                                        @onclick="OpenChordBuilderPanel">
                                    <span class="bi bi-music-note-list" aria-hidden="true"></span>
                                    <span>Chords</span>
                                </button>

                                <button class="pans-page__menu-item"
                                        type="button"
                                        role="menuitem"
                                        @onclick="OpenMetronomePanel">
                                    <span class="bi bi-music-note-beamed" aria-hidden="true"></span>
                                    <span>Metronome</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>

                @if (showChordBuilderPanel_)
                {
                    <div class="pans-page__floating-panel pans-page__floating-panel--left">
                        <div class="pans-page__floating-panel-header">
                            <div class="pans-page__floating-panel-title-wrap">
                                <span class="bi bi-music-note-list pans-page__floating-panel-icon" aria-hidden="true"></span>
                                <span class="pans-page__floating-panel-title">Chords</span>
                            </div>

                            <button class="pans-page__floating-panel-close"
                                    type="button"
                                    aria-label="Close chords panel"
                                    @onclick="CloseChordBuilderPanel">
                                <span class="bi bi-x-lg" aria-hidden="true"></span>
                            </button>
                        </div>

                        <div class="pans-page__floating-panel-body">
                            <ChordBuilder OnChordSelected="SelectChordAsync"
                                          OnPlay="PlaySelectedNotesAsync"
                                          Disabled="@(isMidiPlaying_ || activeMidiPans_.Count == 0)" />
                        </div>
                    </div>
                }

                @if (showMetronomePanel_)
                {
                    <div class="pans-page__floating-panel pans-page__floating-panel--left pans-page__floating-panel--metronome">
                        <div class="pans-page__floating-panel-header">
                            <div class="pans-page__floating-panel-title-wrap">
                                <span class="bi bi-music-note-beamed pans-page__floating-panel-icon" aria-hidden="true"></span>
                                <span class="pans-page__floating-panel-title">Metronome</span>
                            </div>

                            <div class="pans-page__floating-panel-header-actions">
                                <label class="metronome-shell__status-switch">
                                    <input class="metronome-shell__status-switch-input"
                                           type="checkbox"
                                           checked="@metronomeEnabled_"
                                           @onchange="OnMetronomeEnabledShellChangedAsync"
                                           aria-label="Enable metronome" />

                                    <span class="metronome-shell__status-switch-track" aria-hidden="true">
                                        <span class="metronome-shell__status-switch-thumb"></span>
                                    </span>
                                </label>

                                <button class="pans-page__floating-panel-close"
                                        type="button"
                                        aria-label="Close metronome panel"
                                        @onclick="CloseMetronomePanel">
                                    <span class="bi bi-x-lg" aria-hidden="true"></span>
                                </button>
                            </div>
                        </div>

                        <div class="pans-page__floating-panel-body pans-page__floating-panel-body--metronome">
                            <Metronome @ref="metronome_"
                                       Enabled="@metronomeEnabled_"
                                       EnabledChanged="OnMetronomeEnabledChangedAsync"
                                       Bpm="@metronomeBpm_"
                                       BpmChanged="OnMetronomeBpmChangedAsync"
                                       BeatsPerBar="@metronomeBeatsPerBar_"
                                       BeatsPerBarChanged="OnMetronomeBeatsPerBarChangedAsync"
                                       BeatUnit="@metronomeBeatUnit_"
                                       BeatUnitChanged="OnMetronomeBeatUnitChangedAsync"
                                       MidiLoaded="@(activeMidiPans_.Count > 0)"
                                       MidiStartAt="@midiStartAt_" />
                        </div>
                    </div>
                }

                <div class="pans-page__pan-stage">
                    <div class="pans-page__assigned-pans">
                        @foreach (var assignedPan in activeMidiPans_)
                        {
                            <section class="sp-section pans-page__assigned-pan" @key="assignedPan.InstanceId">
                                <div class="pans-page__assigned-pan-header">
                                    <div class="pans-page__assigned-pan-copy">
                                        <div class="pans-page__assigned-pan-title">@assignedPan.TrackLabel</div>
                                        <div class="pans-page__assigned-pan-subtitle">@assignedPan.PanType.ToSpacedPascal()</div>
                                    </div>

                                    <button class="pans-page__assigned-pan-remove"
                                            type="button"
                                            aria-label="Remove @assignedPan.TrackLabel"
                                            disabled="@isMidiPlaying_"
                                            @onclick="() => RemoveTrackAssignmentAsync(assignedPan.TrackIndex)">
                                        <span class="bi bi-x-lg" aria-hidden="true"></span>
                                    </button>
                                </div>

                                <SteelPanView Pan="@assignedPan.Pan"
                                              InstanceChanged="@(view => RegisterAssignedSteelPanViewAsync(assignedPan.InstanceId, view))" />
                            </section>
                        }
                    </div>
                </div>
            </section>
        }
    }
</div>
