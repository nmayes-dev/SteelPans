@page "/"
@page "/pans"
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Services
@using SteelPans.WebApp.Extensions
@inject IJSRuntime JS
@inject SteelPanLoader PanLoader
@inject MidiService MidiService

<div class="pans-page">
    <header class="sp-section pans-page__hero">
        <div class="pans-page__hero-content">
            <h1 class="pans-page__title">Steel Pans</h1>
            <label class="pans-page__eyebrow">Interactive practice tool</label>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(loadError_))
    {
        <div class="alert alert-danger">@loadError_</div>
    }
    else if (pans_.Count == 0)
    {
        <div class="pans-page__empty">No pans found.</div>
    }
    else
    {
        <section class="pans-page__top-grid">
            <MidiLoader FileName="@midiFileName_"
                        Tracks="@midiTracks_"
                        Assignments="@midiTrackAssignments_"
                        OnSingleMidiSelected="OnSingleMidiSelectedAsync"
                        OnMultipleMidiSelected="OnMultipleMidiSelectedAsync"
                        OnTrackAdded="(track) => OpenAddModal(track.Index)"
                        OnTrackRemoved="async (track) => await RemoveTrackAssignmentAsync(track.Index)" />

            <ModalPopup IsOpen="@showMergeMidiModal_"
                        Title="Merge MIDI tracks"
                        Subtitle="Enter a name for the merged track"
                        OnClose="CloseMergeMidiModal">
                <ChildContent>
                    <input id="merge-midi-track-name"
                           class="form-control"
                           @bind="mergeMidiFileName_"
                           @bind:event="oninput" />
                </ChildContent>

                <Actions>
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="CloseMergeMidiModal">
                        Cancel
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            disabled="@string.IsNullOrWhiteSpace(mergeMidiFileName_)"
                            @onclick="ConfirmMergeMidiAsync">
                        Merge
                    </button>
                </Actions>
            </ModalPopup>
        </section>

        @if (activeMidiPans_.Any(x => x.MidiPan.Events.Count > 0))
        {
            <section class="pans-page__midi-controls">
                <MidiPlaybackControl CurrentTime="@playbackPosition_"
                                     TotalTime="@playbackDuration_"
                                     IsPlaying="@isMidiPlaying_"
                                     CanGoToStart="@(playbackPosition_ > TimeSpan.Zero)"
                                     CanGoNext="@(playbackPosition_ < playbackDuration_)"
                                     OnPlayPause="ToggleMidiAsync"
                                     OnBackToStart="SeekToStartAsync"
                                     OnNextTrack="HandleNextTrackAsync"
                                     OnSeekPreviewChanged="HandleSeekPreviewChangedAsync"
                                     OnSeekCommitted="HandleSeekCommittedAsync" />
            </section>
        }
        
        <section class="pans-page__content">
            <div class="pans-page__toolbar">
                <Toolbar @ref="toolsToolbar_"
                         MenuButtonLabel="Open Tools"
                         MenuAriaLabel="Tools"
                         Side="Toolbar.ToolbarSide.Left"
                         OnOpen="() => OnOpenToolbar(toolsToolbar_)">

                    <ToolbarElement Title="Add Pan"
                                    IconClass="bi bi-plus-lg"
                                    OnClick="() => OpenAddModal()" />

                    <ToolbarElement Title="Chords"
                                    IconClass="bi bi-music-note-list">
                        <ChordBuilder OnChordSelected="SelectChordAsync"
                                      OnPlay="PlaySelectedNotesAsync"
                                      Disabled="@(isMidiPlaying_ || activeMidiPans_.Count == 0)" />
                    </ToolbarElement>


                    <ToolbarElement Title="Metronome"
                                    IconClass="bi bi-music-note-beamed">
                        <HeaderActions>
                            <label class="metronome-shell__status-switch">
                                <input class="metronome-shell__status-switch-input"
                                       type="checkbox"
                                       checked="@metronomeEnabled_"
                                       @onchange="OnMetronomeEnabledShellChangedAsync"
                                       aria-label="Enable metronome" />

                                <span class="metronome-shell__status-switch-track" aria-hidden="true">
                                    <span class="metronome-shell__status-switch-thumb"></span>
                                </span>
                            </label>
                        </HeaderActions>
                        <ChildContent>
                            <Metronome @ref="metronome_"
                                       Enabled="@metronomeEnabled_"
                                       EnabledChanged="OnMetronomeEnabledChangedAsync"
                                       Bpm="@metronomeBpm_"
                                       BpmChanged="OnMetronomeBpmChangedAsync"
                                       BeatsPerBar="@metronomeBeatsPerBar_"
                                       BeatsPerBarChanged="OnMetronomeBeatsPerBarChangedAsync"
                                       BeatUnit="@metronomeBeatUnit_"
                                       BeatUnitChanged="OnMetronomeBeatUnitChangedAsync"
                                       MidiLoaded="@(activeMidiPans_.Count > 0)"
                                       MidiStartAt="@midiStartAt_" />
                        </ChildContent>
                    </ToolbarElement>
                </Toolbar>
            </div>

            <div class="pans-page__pan-stage">
                <div class="pans-page__assigned-pans">
                    @foreach (var assignedPan in activeMidiPans_)
                    {
                        <section class="sp-section pans-page__assigned-pan" @key="assignedPan.MidiPan.InstanceId">
                            <div class="pans-page__assigned-pan-header">
                                <div class="pans-page__assigned-pan-copy">
                                    <div class="pans-page__assigned-pan-title">@assignedPan.MidiPan.TrackLabel</div>
                                    <div class="pans-page__assigned-pan-subtitle">@assignedPan.MidiPan.PanType.ToSpacedPascal()</div>
                                </div>
                                <Toolbar @ref="assignedPan.Toolbar"
                                         MenuButtonLabel="Open Pan Actions"
                                         MenuAriaLabel="Pan Actions"
                                         Side="Toolbar.ToolbarSide.Right"
                                         OnOpen="() => OnOpenToolbar(assignedPan.Toolbar)">
                                    <ToolbarElement Title="Remove"
                                                    IconClass="bi bi-trash3"
                                                    OnClick="() => RemoveTrackAssignmentAsync(assignedPan.MidiPan.TrackIndex)" />
                                    <ToolbarElement Title="Volume"
                                                    IconClass="bi bi-volume-up-fill">
                                        <VolumeControl Volume="@assignedPan.MidiPan.Volume"
                                                       VolumeChanged="@(value => OnPanVolumeChangedAsync(assignedPan.MidiPan, value))" />
                                    </ToolbarElement>
                                </Toolbar>
                            </div>

                            <div class="pans-page__assigned-pan-container">
                                <SteelPanView Pan="@assignedPan.MidiPan.Pan"
                                              InstanceChanged="@(view => RegisterAssignedSteelPanViewAsync(assignedPan.MidiPan.InstanceId, view))" />
                            </div>
                        </section>
                    }
                </div>
            </div>
        </section>

        <AddPanModal @ref="addPanModal_"
                     Assignments="@midiTrackAssignments_"
                     AvailablePanTypes="@AvailablePanTypes"
                     Tracks="@midiTracks_"
                     OnAddTrack="AddTrackAssignmentAsync" />
    }
</div>
