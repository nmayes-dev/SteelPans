@page "/"
@page "/pans"
@using SteelPans.WebApp.Model
@using SteelPans.WebApp.Services
@using SteelPans.WebApp.Extensions
@inject IJSRuntime JS
@inject SteelPanLoader PanLoader
@inject MidiLoaderService MidiService
@inject MidiPlaybackService Playback
@inject IOptions<StartupSettings> StartupSettingsAccessor

<PageTitle>Steel Pans</PageTitle>

<div class="pans-page">
    <header class="sp-section pans-page__hero">
        <div class="pans-page__hero-content">
            <h1 class="pans-page__title">Steel Pans</h1>
            <label class="pans-page__eyebrow">Interactive practice tool</label>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(loadError_))
    {
        <div class="alert alert-danger">@loadError_</div>
    }
    else if (pans_.Count == 0)
    {
        <div class="pans-page__empty">No pans found.</div>
    }
    else
    {
        <section class="pans-page__top-grid">
            <section class="pans-page__midi-loader">
                <MidiLoader FileName="@midiFileName_"
                            Tracks="@midiTracks_"
                            OnSingleMidiSelected="OnSingleMidiSelectedAsync"
                            OnMultipleMidiSelected="OnMultipleMidiSelectedAsync"
                            OnTrackAdded="(track) => addPanModal_!.Open(track.Index)" />
            </section>

            <section class="pans-page__midi-controls @(Playback.ActivePans.Any(x => x.Events.Count > 0) ? "pans-page__midi-controls--visible" : "")">
                <MidiPlaybackControl />
            </section>

            <ModalPopup @ref="addMergedTrackModal_"
                        Title="Merge MIDI tracks"
                        OnClose="CloseMergeMidiModal"
                        OnEnter="ConfirmMergeMidiAsync">
                <ChildContent>
                    <input class="pans-page__track_name form-control"
                           placeholder="Enter merged track name..."
                           @bind="mergeMidiFileName_"
                           @bind:event="oninput" />
                </ChildContent>

                <Actions>
                    <button type="button"
                            class="btn btn-outline-secondary"
                            @onclick="CloseMergeMidiModal">
                        Cancel
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            disabled="@string.IsNullOrWhiteSpace(mergeMidiFileName_)"
                            @onclick="ConfirmMergeMidiAsync">
                        Merge
                    </button>
                </Actions>
            </ModalPopup>
        </section>
        
        <section class="pans-page__content">
            <div class="pans-page__toolbar">
                <Toolbar MenuButtonLabel="Open Tools"
                         MenuLabel="Pan Tools"
                         Side="Toolbar.ToolbarSide.Left">

                    <ToolbarElement Title="Add Pan"
                                    IconClass="bi bi-plus-lg"
                                    OnClick="() => addPanModal_!.Open()" />

                    @if (Playback.ActivePans.Any())
                    {
                        <ToolbarElement Title="Mixer"
                                        IconClass="bi bi-sliders2-vertical"
                                        CanExpand="true">
                            <VolumeMixer />
                        </ToolbarElement>

                        <ToolbarElement Title="Metronome"
                                        IconClass="bi bi-music-note-beamed"
                                        CanExpand="true">
                            <HeaderActions>
                                <label class="metronome-shell__status-switch">
                                    <input class="metronome-shell__status-switch-input"
                                           type="checkbox"
                                           checked="@Playback.ClickTrackEnabled"
                                           @onchange="OnClickTrackEnabledShellChangedAsync"
                                           @onclick:stopPropagation="true"
                                           aria-label="Enable metronome" />

                                    <span class="metronome-shell__status-switch-track" aria-hidden="true">
                                        <span class="metronome-shell__status-switch-thumb"></span>
                                    </span>
                                </label>
                            </HeaderActions>
                            <ChildContent>
                                <Metronome />
                            </ChildContent>
                        </ToolbarElement>

                        <ToolbarElement Title="Chords"
                                        IconClass="bi bi-music-note-list">
                            <ChordBuilder />
                        </ToolbarElement>
                    }


                </Toolbar>
            </div>

            <div class="pans-page__pan-stage">
                <div class="pans-page__assigned-pans"
                     @ref="assignedPansElement_"
                     data-pan-count="@Playback.ActivePans.Count">
                    @foreach (var assignedPan in Playback.ActivePans)
                    {
                        <section class="sp-section pans-page__assigned-pan" @key="assignedPan.InstanceId">
                            <div class="pans-page__assigned-pan-container">
                                <SteelPanView Pan="@assignedPan.Pan"
                                              PlaybackInstanceId="@assignedPan.InstanceId" />
                            </div>
                            <div class="pans-page__assigned-pan-header">
                                <div class="pans-page__assigned-pan-copy">
                                    <div class="pans-page__assigned-pan-title">@assignedPan.Assignment.Track?.Name</div>
                                    <div class="pans-page__assigned-pan-subtitle">@assignedPan.Assignment.AssignedPanType.ToSpacedPascal()</div>
                                </div>
                                <button type="button"
                                        class="pans-page__remove-pan-button"
                                        title="Remove pan"
                                        aria-label="Remove pan"
                                        @onclick="() => OpenRemovePanModal(assignedPan)">
                                    <span class="bi bi-trash3"></span>
                                </button>
                            </div>
                        </section>
                    }
                </div>
            </div>
        </section>

        <AddPanModal @ref="addPanModal_"
                     Pans="@pans_"
                     Tracks="@midiTracks_" />

        var removeTitle = panPendingRemoval_ is not null
            ? $"Remove {panPendingRemoval_.Pan.Type.ToSpacedPascal()}?"
            : "Remove Pan?";

        <ModalPopup @ref="removePanModal_"
                    Title="@removeTitle"
                    ShowCloseButton="false"
                    OnEnter="ConfirmRemovePanAsync">
            <Actions>
                <button type="button"
                        class="btn btn-outline-secondary"
                        @onclick="CloseRemovePanModal">
                    Cancel
                </button>

                <button type="button"
                        class="btn btn-danger"
                        disabled="@(panPendingRemoval_ is null)"
                        @onclick="ConfirmRemovePanAsync">
                    Remove
                </button>
            </Actions>
        </ModalPopup>
    }
</div>
